# FIXME: Configure environment variables for production
# Copy this file to `.env.production.local` and fill in real values.
# NEVER commit `.env.production.local` or any file containing real secrets.
# Set production secrets via your deployment platform's environment variable settings.

# Hosting
# Replace with your domain name
NEXT_PUBLIC_APP_URL=https://example.com

# Sentry DSN
NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn_here

# Stripe
# If you need a real Stripe subscription payment with checkout page, customer portal, webhook, etc.
# You can check out the Next.js Boilerplate Pro: https://nextjs-boilerplate.com/pro-saas-starter-kit
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your_publishable_key_here
# Use Stripe test mode price id or production price id
BILLING_PLAN_ENV=prod

######## [BEGIN] SENSITIVE DATA ########
# For security reasons, do NOT set real secret values here.
# Instead, create `.env.production.local` (git-ignored) or set secrets via your deployment platform.

# Database
# Using an incorrect DATABASE_URL value, Next.js build will timeout and you will get the following error:
# "because it took more than 60 seconds"
DATABASE_URL=postgresql://user:password@localhost:5432/mydb

# Stripe
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret_here

# Error monitoring
SENTRY_AUTH_TOKEN=your_sentry_auth_token_here

# Logging ingestion
LOGTAIL_SOURCE_TOKEN=your_logtail_source_token_here
######## [END] SENSITIVE DATA ########
